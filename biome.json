{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"html": {
		"experimentalFullSupportEnabled": true
	},
	"files": {
		"includes": ["src/**/*.{js,ts,vue}", "vite.config.js"]
	},
	"formatter": {
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineWidth": 200
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "always"
		}
	},
	"linter": {
		"rules": {
			"recommended": true,
			"correctness": {
				"noUndeclaredVariables": "off",
				"noUnknownPseudoClass": "off"
			},
			"style": {
				"useTemplate": "off",
				"noNonNullAssertion": "off"
			},
			"a11y": {
				"noAutofocus": "off"
			},
			"complexity": {
				"useLiteralKeys": "off",
				"noImportantStyles": "off"
			}
		}
	}
}
